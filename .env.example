# Application mode: "dev" or "prod"
MODE=dev

# Backend API host (e.g. "localhost" for dev, "api.olympsis.com" for prod)
API=
USER_ID=

# Apple Developer
APL_APP_ID=
APL_KEY_ID=
APL_TEAM_ID=

# Apple MapKit — MAPKIT_KEY is the PEM-encoded private key (server-only, for JWT signing)
MAPKIT_ORIGIN=
MAPKIT_KEY=

# Firebase
FB_API_KEY=
FB_AUTH_DOMAIN=
FB_PROJECT_ID=
FB_STORAGE_BUCKET=
FB_MESSAGING_SENDER_ID=
FB_APP_ID=
FB_MEASUREMENT_ID=

# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
